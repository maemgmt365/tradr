function renderStrategyBrowser() {
  const enrolled = STRATEGIES.filter(s=>enrolledIds.has(s.id));
  const sec = document.getElementById('enrolledSection');
  if(enrolled.length===0){
    sec.innerHTML='<div class="enroll-empty">You haven\'t enrolled in any strategies yet.<br>Browse below and tap one to get started!</div>';
  } else {
    sec.innerHTML = enrolled.map(s=>{
      const done = s.id==='breakout' ? lessonsCompleted : 0;
      const total = s.modules.reduce((a,m)=>a+m.lessons.length,0);
      const pct = total>0?Math.round(done/total*100):0;
      return `<div class="enrolled-card" onclick="openStrategy('${s.id}')">
        <div class="enrolled-top">
          <div class="enrolled-icon">${s.icon}</div>
          <div>
            <div class="enrolled-name">${s.name}</div>
            <div class="enrolled-sub"><span class="diff-badge ${s.diffC}">${s.diff}</span></div>
          </div>
        </div>
        <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${pct}%"></div></div>
        <div class="progress-label">${done} of ${total} lessons complete · ${pct}%</div>
        <button class="continue-btn" onclick="event.stopPropagation();openStrategy('${s.id}')">Continue →</button>
      </div>`;
    }).join('');
  }
  document.getElementById('stratGrid').innerHTML = STRATEGIES.map(s=>{
    const isE=enrolledIds.has(s.id);
    const total=s.modules.reduce((a,m)=>a+m.lessons.length,0);
