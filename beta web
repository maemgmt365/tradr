  document.getElementById('bnav').classList.remove('show');
  window.addEventListener('resize',()=>{
    const a=document.querySelector('.screen.active');if(!a)return;
    if(a.id==='sl'){drawLessonChart();drawQuizChart();}
    if(a.id==='stiq'&&tiqTestRunning)renderChart(TIQ_SCENARIOS[tiqCurrentScenario]);
  });
})();
</script>
