}
function renderTIQBoard(stratId){
  currentStratTab=stratId;
  renderTIQBoardHeader();
  const data=MOCK_STRAT_RATINGS[stratId]||MOCK_STRAT_RATINGS.overall;
  const all=[...data,{name:'You',rating:tiqRating,av:'🧑',isYou:true}];
  all.sort((a,b)=>b.rating-a.rating);
  const medals=['🥇','🥈','🥉'];
  let html='',yourRank=-1;
  all.forEach((u,i)=>{if(u.isYou)yourRank=i+1;});
  all.forEach((u,i)=>{
    const rank=i+1,isYou=u.isYou,rankStr=rank<=3?medals[rank-1]:rank;
    const t=getTitle(u.rating);
    html+=`<div class="lg-row${isYou?' you-tiq':''}"><div class="lg-rank">${rankStr}</div><div class="lg-av">${u.av}</div><div class="lg-info"><div class="lg-name">${u.name}${isYou?`<span class="you-badge blue">YOU</span>`:''}</div><div class="lg-sub"><span class="title-badge ${t.css}" style="font-size:9px;padding:1px 6px">${t.symbol} ${t.full}</span></div></div><div class="lg-stat"><div class="lg-stat-v blue">${u.rating}</div><div class="lg-stat-l">RATING</div></div></div>`;
    if(!isYou&&i===4&&yourRank>6) html+=`<div class="lg-divider"><span>···</span></div>`;
  });
  document.getElementById('tiqRankingList').innerHTML=html;
}
function renderBlownBoard(){
  const all=[...MOCK_BLOWN];
  if(blownCount>0) all.push({name:'You',blown:blownCount,av:'🧑',isYou:true,quote:'Still learning'});
  all.sort((a,b)=>b.blown-a.blown);
  const medals=['🥇','🥈','🥉'];
  let html='';
  all.forEach((u,i)=>{
    const rank=i+1,isYou=u.isYou,rankStr=rank<=3?medals[rank-1]:rank;
    html+=`<div class="lg-row${isYou?' you-blown':''}"><div class="lg-rank">${rankStr}</div><div class="lg-av">${u.av}</div><div class="lg-info"><div class="lg-name">${u.name}${isYou?'<span class="you-badge" style="background:var(--red)">YOU</span>':''}</div><div class="lg-sub">${u.quote||'Living dangerously'}</div></div><div class="lg-stat"><div class="lg-stat-v red">${u.blown}</div><div class="lg-stat-l">BLOWN 💥</div></div></div>`;
  });
  if(!blownCount) html+=`<div style="text-align:center;padding:20px;color:var(--muted);font-size:13px">Blow your demo account in the TradeIQ test to appear here 🎰</div>`;
  document.getElementById('blownLeaderboard').innerHTML=html;
}

// ════ PROFILE ════
function updateProfile(){
  document.getElementById('profXP').textContent=xp;
  document.getElementById('profXPStat').textContent=xp;
  document.getElementById('profBlown').textContent=blownCount;
  const card=document.getElementById('profTIQCard');
  const t=getTitle(tiqRating);
  if(tiqScore!==null){
    card.classList.remove('empty');
    document.getElementById('profTIQScore').textContent=tiqRating;
    document.getElementById('profTitleBadge').innerHTML=titleBadgeHTML(tiqRating);
    document.getElementById('profTIQLabel').textContent=`Last Score: ${tiqScore}/100`;
    document.getElementById('profTIQSub').textContent=`${t.full} · Tap to retake`;
  } else {
    card.classList.add('empty');
    document.getElementById('profTIQScore').textContent=tiqRating;
    document.getElementById('profTitleBadge').innerHTML=titleBadgeHTML(tiqRating);
    document.getElementById('profTIQLabel').textContent='Take the TradeIQ Test';
    document.getElementById('profTIQSub').textContent='Earn your title and climb the rankings';
  }
  checkAchievements();
}

// ════ ACHIEVEMENTS ════
function checkAchievements(){
  if(enrolledIds.size>=2) document.getElementById('ach2strats').classList.remove('locked');
  if(xp>=50) document.getElementById('ach50xp').classList.remove('locked');
  if(tiqScore!==null) document.getElementById('achTIQ').classList.remove('locked');
  if(tiqScore!==null&&tiqScore>=70) document.getElementById('achTIQ70').classList.remove('locked');
  if(blownCount>=1) document.getElementById('achBlown').classList.remove('locked');
  if(blownCount>=5) document.getElementById('achBlown5').classList.remove('locked');
}

