    const inWin=sc.entryWindow.includes(entryCandle),dirOk=dir===sc.correctDir;
    if(dirOk&&inWin){
      pts=33;oClass='win';oText='✅ Perfect Trade';balChange=sc.pnl.perfect;
      pText=`Balance → $${Math.max(0,demoBalance+balChange).toFixed(0)} (+$${balChange})`;
