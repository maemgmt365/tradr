<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tradr</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0f0f13; --surface: #1a1a24; --surface2: #22222f; --border: #2e2e40;
      --accent: #58cc02; --accent-dark: #46a302; --accent-glow: rgba(88,204,2,.2);
      --red: #ff4b4b; --gold: #ffd700; --blue: #4b9dff; --purple: #b07dff;
      --text: #e8e8f0; --muted: #888899; --r: 14px;
    }
    html, body { height: 100%; background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; overflow: hidden; }
    .screen { display: none; position: absolute; inset: 0; flex-direction: column; align-items: center; overflow-y: auto; padding-bottom: 66px; }
    .screen.active { display: flex; }
    .screen.no-nav { padding-bottom: 0; }

    /* NAV */
    .bnav { position: fixed; bottom: 0; left: 0; right: 0; height: 62px; background: var(--surface); border-top: 1px solid var(--border); display: none; align-items: center; justify-content: space-around; z-index: 200; }
    .bnav.show { display: flex; }
    .bnav-btn { background: none; border: none; color: var(--muted); font-size: 18px; cursor: pointer; padding: 5px 10px; display: flex; flex-direction: column; align-items: center; gap: 2px; transition: color .2s; }
    .bnav-btn .bl { font-size: 9px; font-weight: 800; letter-spacing: .5px; }
    .bnav-btn.on { color: var(--accent); }

    /* HOME */
    #sh { justify-content: center; background: linear-gradient(160deg,#0f0f13,#131320); padding: 36px 22px; gap: 0; }
    .home-logo { font-size: 44px; font-weight: 900; letter-spacing: -2px; color: #fff; margin-bottom: 4px; }
    .home-logo span { color: var(--accent); }
    .home-sub { font-size: 14px; color: var(--muted); margin-bottom: 26px; }
    .xp-badge { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 20px 32px; text-align: center; margin-bottom: 12px; width: 100%; max-width: 340px; }
    .xp-big { font-size: 52px; font-weight: 900; color: var(--accent); line-height: 1; }
    .xp-label { font-size: 11px; font-weight: 800; letter-spacing: 2px; color: var(--muted); text-transform: uppercase; margin-top: 4px; }
    .xp-sub { font-size: 12px; color: var(--muted); margin-top: 5px; }
    .home-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 16px 18px; width: 100%; max-width: 340px; margin-bottom: 10px; }
    .home-card.clickable { cursor: pointer; transition: border-color .2s; }
    .home-card.clickable:hover { border-color: var(--blue); }
    .hc-lbl { font-size: 10px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent); margin-bottom: 5px; }
    .hc-lbl.blue { color: var(--blue); }
    .hc-title { font-size: 16px; font-weight: 800; margin-bottom: 3px; }
    .hc-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }
    .cta { background: var(--accent); color: #0f0f13; border: none; border-radius: 12px; padding: 15px; font-size: 16px; font-weight: 800; cursor: pointer; width: 100%; max-width: 340px; box-shadow: 0 4px 20px var(--accent-glow); transition: transform .1s; }
    .cta:active { transform: scale(.97); }

    /* STRATEGY BROWSER */
    #sm { padding: 0; padding-bottom: 66px; }
    .map-hdr { width: 100%; background: var(--surface); border-bottom: 1px solid var(--border); padding: 13px 18px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .map-logo { font-size: 20px; font-weight: 900; color: #fff; letter-spacing: -1px; }
    .map-logo span { color: var(--accent); }
    .xp-pill { background: var(--surface2); border: 1px solid var(--border); border-radius: 20px; padding: 5px 13px; font-size: 12px; font-weight: 700; color: var(--gold); }
    .strat-scroll { flex: 1; width: 100%; overflow-y: auto; padding: 16px; }
    .sec-lbl { font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; }

    /* Enrolled strategy cards */
    .enrolled-card { background: var(--surface); border: 1px solid var(--accent); border-radius: var(--r); padding: 14px 16px; margin-bottom: 10px; cursor: pointer; transition: border-color .2s, box-shadow .2s; }
    .enrolled-card:hover { box-shadow: 0 0 16px var(--accent-glow); }
    .enrolled-top { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
    .enrolled-icon { font-size: 28px; flex-shrink: 0; }
    .enrolled-name { font-size: 15px; font-weight: 900; }
    .enrolled-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }
    .progress-bar-wrap { background: var(--surface2); border-radius: 10px; height: 8px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: var(--accent); border-radius: 10px; transition: width .5s ease; }
    .progress-label { font-size: 10px; color: var(--muted); margin-top: 4px; font-weight: 700; }
    .continue-btn { background: var(--accent); color: #0f0f13; border: none; border-radius: 10px; padding: 10px 16px; font-size: 13px; font-weight: 800; cursor: pointer; margin-top: 10px; width: 100%; transition: transform .1s; }
    .continue-btn:active { transform: scale(.97); }
    .enroll-empty { background: var(--surface); border: 1px dashed var(--border); border-radius: var(--r); padding: 20px; text-align: center; color: var(--muted); font-size: 13px; margin-bottom: 16px; }

    /* Strategy grid (browse all) */
    .strat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
    .strat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 14px 12px; cursor: pointer; transition: border-color .2s, transform .1s; position: relative; }
    .strat-card:hover { border-color: var(--accent); transform: scale(1.02); }
    .strat-card.enrolled-border { border-color: rgba(88,204,2,.4); }
    .strat-card-icon { font-size: 26px; margin-bottom: 6px; }
    .strat-card-name { font-size: 13px; font-weight: 800; line-height: 1.3; margin-bottom: 5px; }
    .strat-card-desc { font-size: 10px; color: var(--muted); line-height: 1.4; margin-bottom: 6px; }
    .enrolled-check { position: absolute; top: 8px; right: 8px; font-size: 13px; }
    .diff-badge { font-size: 9px; font-weight: 800; letter-spacing: .8px; padding: 2px 7px; border-radius: 20px; text-transform: uppercase; display: inline-block; }
    .diff-easy { background: rgba(88,204,2,.15); color: var(--accent); border: 1px solid rgba(88,204,2,.3); }
    .diff-med { background: rgba(255,200,0,.15); color: var(--gold); border: 1px solid rgba(255,200,0,.3); }
    .diff-hard { background: rgba(255,75,75,.15); color: var(--red); border: 1px solid rgba(255,75,75,.3); }

    /* STRATEGY MAP */
    #smap { padding: 0; padding-bottom: 66px; }
    .smap-hdr { width: 100%; background: var(--surface); border-bottom: 1px solid var(--border); padding: 12px 16px; display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
    .back-icon { background: none; border: none; color: var(--muted); font-size: 20px; cursor: pointer; padding: 4px; flex-shrink: 0; }
    .smap-title-wrap { flex: 1; min-width: 0; }
    .smap-title { font-size: 16px; font-weight: 900; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .smap-sub { font-size: 11px; color: var(--muted); }
    .map-scroll { flex: 1; width: 100%; overflow-y: auto; padding: 20px 20px 14px; }
    .streak-bar { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 12px 16px; display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
    .streak-fire { font-size: 24px; }
    .streak-info strong { font-size: 15px; font-weight: 900; }
    .streak-info p { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .module-lbl { font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; }
    .node-row { display: flex; justify-content: center; margin-bottom: 6px; }
    .node { display: flex; flex-direction: column; align-items: center; cursor: pointer; }
    .nc { width: 70px; height: 70px; border-radius: 50%; background: var(--surface2); border: 3px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 26px; transition: transform .15s, box-shadow .15s; }
    .node.done .nc { background: var(--accent); border-color: var(--accent-dark); box-shadow: 0 0 18px var(--accent-glow); }
    .node.cur .nc { background: var(--accent); border-color: var(--accent-dark); animation: pulse 2s infinite; }
    .node.locked .nc { opacity: .32; cursor: default; }
    .node.soon .nc { opacity: .55; cursor: default; border-style: dashed; }
    @keyframes pulse { 0%,100%{box-shadow:0 0 28px rgba(88,204,2,.4)}50%{box-shadow:0 0 44px rgba(88,204,2,.75)} }
    .node:not(.locked):not(.soon) .nc:hover { transform: scale(1.06); }
    .nl { font-size: 11px; font-weight: 700; color: var(--muted); margin-top: 7px; text-align: center; max-width: 84px; line-height: 1.3; }
    .node.done .nl, .node.cur .nl { color: var(--text); }
    .conn { width: 3px; height: 26px; background: var(--border); margin: 0 auto 6px; border-radius: 2px; }
    .conn.done { background: var(--accent); }
    .sec-div { margin: 20px 0 16px; border-top: 1px solid var(--border); padding-top: 16px; }
    .coming-soon-bar { background: var(--surface); border: 1px dashed var(--border); border-radius: var(--r); padding: 14px; text-align: center; margin-top: 10px; }
    .coming-soon-bar p { font-size: 12px; color: var(--muted); }
    .coming-soon-bar strong { color: var(--text); }

    /* LESSON */
    #sl { padding: 0; }
    .les-hdr { width: 100%; display: flex; align-items: center; gap: 12px; padding: 12px 12px 8px; flex-shrink: 0; }
    .back-btn { background: none; border: none; color: var(--muted); font-size: 20px; cursor: pointer; padding: 4px; flex-shrink: 0; }
    .prog-bar { flex: 1; height: 10px; background: var(--surface2); border-radius: 10px; overflow: hidden; }
    .prog-fill { height: 100%; background: var(--accent); border-radius: 10px; transition: width .4s ease; }
    .hearts { display: flex; gap: 2px; font-size: 16px; flex-shrink: 0; }
    .heart.lost { opacity: .2; filter: grayscale(1); }
    .les-body { flex: 1; width: 100%; max-width: 480px; margin: 0 auto; padding: 4px 16px 120px; overflow-y: auto; }
    .step { display: none; }
    .step.on { display: block; }
    .step-lbl { font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
    .step-title { font-size: 22px; font-weight: 900; line-height: 1.2; margin-bottom: 16px; }
    .step-txt { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 16px; font-size: 14px; line-height: 1.75; margin-bottom: 12px; }
    .hl { color: var(--accent); font-weight: 700; }
    .chart-wrap { border-radius: var(--r); overflow: hidden; margin-bottom: 12px; border: 1px solid var(--border); }
    .chart-wrap canvas { display: block; width: 100%; }
    .chart-lbl { background: var(--surface2); padding: 7px 12px; font-size: 10px; color: var(--muted); display: flex; gap: 14px; flex-wrap: wrap; }
    .chart-lbl span { display: flex; align-items: center; gap: 4px; }
    .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .les-foot { padding-top: 6px; }
    .next-btn { background: var(--accent); color: #0f0f13; border: none; border-radius: 12px; padding: 14px; font-size: 15px; font-weight: 800; cursor: pointer; width: 100%; box-shadow: 0 4px 18px var(--accent-glow); transition: transform .1s; }
    .next-btn:active { transform: scale(.97); }
    .quiz-q { font-size: 16px; font-weight: 700; line-height: 1.5; margin-bottom: 18px; }
    .opts { display: flex; flex-direction: column; gap: 9px; }
    .opt { background: var(--surface); border: 2px solid var(--border); border-radius: 12px; padding: 12px 14px; font-size: 13px; font-weight: 600; color: var(--text); cursor: pointer; text-align: left; display: flex; align-items: center; gap: 11px; transition: border-color .15s, background .15s; }
    .opt:hover:not(:disabled) { border-color: var(--accent); background: rgba(88,204,2,.07); }
    .opt:disabled { cursor: default; }
    .opt.ok { border-color: var(--accent); background: rgba(88,204,2,.1); }
    .opt.bad { border-color: var(--red); background: rgba(255,75,75,.1); }
    .ol { width: 26px; height: 26px; border-radius: 50%; background: var(--surface2); border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 800; flex-shrink: 0; }
    .fb { display: none; position: sticky; bottom: 0; padding: 16px; border-top: 1px solid var(--border); background: var(--surface); }
    .fb.show { display: block; }
    .fb.ok { background: rgba(88,204,2,.07); border-color: var(--accent); }
    .fb.bad { background: rgba(255,75,75,.07); border-color: var(--red); }
    .fb-title { font-size: 15px; font-weight: 900; margin-bottom: 3px; }
    .fb.ok .fb-title { color: var(--accent); }
    .fb.bad .fb-title { color: var(--red); }
    .fb-text { font-size: 12px; color: var(--muted); margin-bottom: 12px; }
    .cont-btn { border: none; border-radius: 12px; padding: 12px; font-size: 14px; font-weight: 800; cursor: pointer; width: 100%; transition: transform .1s; }
    .fb.ok .cont-btn { background: var(--accent); color: #0f0f13; }
    .fb.bad .cont-btn { background: var(--red); color: #fff; }
    .cont-btn:active { transform: scale(.97); }

    /* TRADEIQ */
    #stiq { padding: 0; padding-bottom: 66px; }
    .tiq-hdr { width: 100%; background: var(--surface); border-bottom: 1px solid var(--border); padding: 11px 16px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; gap: 10px; }
    .tiq-hdr-logo { font-size: 17px; font-weight: 900; flex-shrink: 0; }
    .tiq-hdr-logo span { color: var(--blue); }
    .bal-pill { background: var(--surface2); border: 1px solid var(--border); border-radius: 20px; padding: 4px 12px; font-size: 12px; font-weight: 700; color: var(--accent); transition: color .3s; }
    .bal-pill.danger { color: var(--red); border-color: rgba(255,75,75,.4); }
    .tiq-score-pill { background: var(--surface2); border: 1px solid var(--border); border-radius: 20px; padding: 4px 12px; font-size: 12px; font-weight: 700; color: var(--blue); flex-shrink: 0; }
    .diff-badge-lg { font-size: 10px; font-weight: 800; letter-spacing: 1px; padding: 3px 9px; border-radius: 20px; text-transform: uppercase; }
    .tiq-intro { padding: 22px 20px; width: 100%; max-width: 480px; margin: 0 auto; }
    .tiq-intro-icon { font-size: 52px; text-align: center; margin-bottom: 12px; }
    .tiq-intro-title { font-size: 24px; font-weight: 900; text-align: center; margin-bottom: 6px; }
    .tiq-intro-title span { color: var(--blue); }
    .tiq-intro-sub { font-size: 13px; color: var(--muted); text-align: center; line-height: 1.6; margin-bottom: 16px; }
    .bal-display { background: rgba(88,204,2,.07); border: 1px solid rgba(88,204,2,.25); border-radius: var(--r); padding: 14px 20px; text-align: center; margin-bottom: 16px; }
    .bal-display-val { font-size: 36px; font-weight: 900; color: var(--accent); }
    .bal-display-lbl { font-size: 11px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); margin-top: 3px; }
    .bal-display-sub { font-size: 12px; color: var(--muted); margin-top: 5px; }
    .blown-tag { display: inline-block; background: rgba(255,75,75,.15); border: 1px solid rgba(255,75,75,.3); color: var(--red); border-radius: 20px; padding: 4px 12px; font-size: 11px; font-weight: 800; margin-top: 8px; }
    .tiq-scenarios { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .tiq-sc-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 12px 14px; display: flex; align-items: center; gap: 12px; }
    .tiq-sc-num { width: 30px; height: 30px; border-radius: 50%; background: var(--surface2); border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; flex-shrink: 0; }
    .tiq-sc-info strong { font-size: 13px; font-weight: 800; display: block; margin-bottom: 3px; }
    .tiq-start-btn { background: var(--blue); color: #fff; border: none; border-radius: 12px; padding: 15px; font-size: 15px; font-weight: 800; cursor: pointer; width: 100%; box-shadow: 0 4px 20px rgba(75,157,255,.25); transition: transform .1s; }
    .tiq-start-btn:active { transform: scale(.97); }
    .tiq-body { flex: 1; width: 100%; max-width: 520px; margin: 0 auto; padding: 12px 14px 0; }
    .tiq-progress { display: flex; gap: 5px; margin-bottom: 12px; }
    .tiq-prog-step { flex: 1; height: 5px; border-radius: 5px; background: var(--border); }
    .tiq-prog-step.done { background: var(--accent); }
    .tiq-prog-step.cur { background: var(--blue); }
    .prac-info { display: flex; gap: 8px; margin-bottom: 10px; }
    .prac-stat { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 9px 10px; flex: 1; text-align: center; }
    .prac-stat-v { font-size: 13px; font-weight: 800; }
    .prac-stat-l { font-size: 9px; color: var(--muted); font-weight: 700; letter-spacing: .5px; margin-top: 2px; }
    .prac-chart-wrap { border-radius: var(--r); overflow: hidden; border: 1px solid var(--border); margin-bottom: 10px; }
    .prac-chart-wrap canvas { display: block; width: 100%; }
    .prac-desc { font-size: 12px; color: var(--muted); line-height: 1.5; margin-bottom: 10px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 10px 12px; }
    .prac-actions { display: flex; gap: 8px; margin-bottom: 10px; }
    .act-btn { flex: 1; border: none; border-radius: 12px; padding: 13px 8px; font-size: 13px; font-weight: 800; cursor: pointer; transition: transform .1s, opacity .2s; }
    .act-btn:active { transform: scale(.96); }
    .act-btn:disabled { opacity: .35; cursor: default; }
    .btn-long { background: var(--accent); color: #0f0f13; }
    .btn-short { background: var(--red); color: #fff; }
    .btn-next-c { background: var(--surface2); color: var(--text); border: 1px solid var(--border); flex: none; padding: 13px 16px; }
    .prac-result { display: none; background: var(--surface); border: 1px solid var(--border); border-radius: var(--r); padding: 16px; margin-bottom: 10px; }
    .prac-result.show { display: block; }
    .res-outcome { font-size: 18px; font-weight: 900; margin-bottom: 4px; }
    .res-outcome.win { color: var(--accent); }
    .res-outcome.loss { color: var(--red); }
    .res-outcome.warn { color: var(--gold); }
    .res-pnl { font-size: 13px; font-weight: 700; margin-bottom: 6px; }
    .res-text { font-size: 12px; color: var(--muted); line-height: 1.6; }
    .res-tag { display: inline-block; border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 800; margin-top: 8px; }
    .res-tag.pos { background: rgba(88,204,2,.12); border: 1px solid rgba(88,204,2,.3); color: var(--accent); }
    .res-tag.neg { background: rgba(255,75,75,.12); border: 1px solid rgba(255,75,75,.3); color: var(--red); }
    .res-tag.neu { background: rgba(255,200,0,.12); border: 1px solid rgba(255,200,0,.3); color: var(--gold); }
    .prac-nav { display: flex; gap: 8px; }
    .prac-nav-btn { flex: 1; border: none; border-radius: 12px; padding: 12px; font-size: 13px; font-weight: 800; cursor: pointer; transition: transform .1s; }
    .prac-nav-btn:active { transform: scale(.97); }
    .btn-advance { background: var(--blue); color: #fff; }
    .btn-blown { background: var(--red); color: #fff; }
    .tiq-blown { display: none; padding: 28px 20px; width: 100%; max-width: 480px; margin: 0 auto; flex-direction: column; align-items: center; }
    .tiq-blown.show { display: flex; }
    .blown-emoji { font-size: 72px; margin-bottom: 14px; animation: shake .5s ease; }
    @keyframes shake { 0%,100%{transform:rotate(0)}20%{transform:rotate(-10deg)}40%{transform:rotate(10deg)}60%{transform:rotate(-8deg)}80%{transform:rotate(8deg)} }
    .blown-title { font-size: 28px; font-weight: 900; color: var(--red); margin-bottom: 6px; text-align: center; }
    .blown-count-badge { background: rgba(255,75,75,.12); border: 1px solid rgba(255,75,75,.3); border-radius: 20px; padding: 6px 16px; font-size: 13px; font-weight: 800; color: var(--red); margin-bottom: 16px; }
    .blown-quote { font-size: 14px; color: var(--muted); text-align: center; line-height: 1.6; margin-bottom: 24px; max-width: 300px; font-style: italic; }
    .blown-fresh-btn { background: var(--accent); color: #0f0f13; border: none; border-radius: 12px; padding: 14px; font-size: 15px; font-weight: 800; cursor: pointer; width: 100%; box-shadow: 0 4px 16px var(--accent-glow); margin-bottom: 10px; }
    .blown-lb-btn { background: var(--surface2); color: var(--text); border: 1px solid var(--border); border-radius: 12px; padding: 13px; font-size: 14px; font-weight: 800; cursor: pointer; width: 100%; }
    .tiq-final { display: none; padding: 22px 20px; width: 100%; max-width: 480px; margin: 0 auto; flex-direction: column; align-items: center; }
    .tiq-final.show { display: flex; }
    @keyframes pop { from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1} }
    .tiq-final-icon { font-size: 60px; margin-bottom: 12px; animation: pop .4s cubic-bezier(.34,1.56,.64,1); }
    .tiq-score-big { font-size: 76px; font-weight: 900; color: var(--blue); line-height: 1; }
    .tiq-score-denom { font-size: 26px; color: var(--muted); font-weight: 700; }
    .tiq-tier { font-size: 13px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: var(--blue); margin-top: 5px; margin-bottom: 18px; }
