function iC(el){
  const dpr=window.devicePixelRatio||1,w=el.offsetWidth||400,h=parseInt(el.getAttribute('height'))||200;
  el.width=w*dpr;el.height=h*dpr;
  const ctx=el.getContext('2d');ctx.scale(dpr,dpr);
  return{ctx,w,h};
}
function drawCandles(ctx,candles,W,H,opts={}){
  const pad={t:16,r:50,b:24,l:5};
  let lo=1e9,hi=-1e9;candles.forEach(c=>{lo=Math.min(lo,c.l);hi=Math.max(hi,c.h);});
  const rng=hi-lo,plo=lo-rng*.1,phi=hi+rng*.14;
  const toY=p=>H-pad.b-((p-plo)/(phi-plo))*(H-pad.t-pad.b);
  const slot=(W-pad.l-pad.r)/candles.length,cw=Math.max(5,slot*.55),cx=i=>pad.l+(i+.5)*slot;
  ctx.fillStyle='#1a1a24';ctx.fillRect(0,0,W,H);
  for(let i=0;i<=4;i++){
    const p=plo+(phi-plo)*i/4,y=toY(p);
    ctx.strokeStyle='rgba(255,255,255,0.04)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(W-pad.r,y);ctx.stroke();
    ctx.fillStyle='#505060';ctx.font='10px system-ui';ctx.textAlign='right';ctx.fillText(p.toFixed(1),W-3,y+4);
  }
  if(opts.orbH&&opts.orbL){
    ctx.fillStyle='rgba(88,204,2,0.06)';ctx.fillRect(pad.l,toY(opts.orbH),W-pad.l-pad.r,toY(opts.orbL)-toY(opts.orbH));
    [['orbH','rgba(88,204,2,.7)','#58cc02','ORB Hi',-3],['orbL','rgba(255,75,75,.7)','#ff4b4b','ORB Lo',10]].forEach(([k,sc,fc,lbl,dy])=>{
      ctx.setLineDash([5,4]);ctx.strokeStyle=sc;ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(pad.l,toY(opts[k]));ctx.lineTo(W-pad.r-2,toY(opts[k]));ctx.stroke();
      ctx.setLineDash([]);ctx.fillStyle=fc;ctx.font='9px system-ui';ctx.textAlign='right';ctx.fillText(lbl,W-3,toY(opts[k])+dy);
    });
  }
  if(opts.entryPrice!=null){
    ctx.setLineDash([3,4]);ctx.strokeStyle='rgba(255,200,0,.8)';ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(pad.l,toY(opts.entryPrice));ctx.lineTo(W-pad.r,toY(opts.entryPrice));ctx.stroke();
    ctx.setLineDash([]);ctx.fillStyle='#ffd700';ctx.font='9px system-ui';ctx.textAlign='right';ctx.fillText('Entry',W-3,toY(opts.entryPrice)-3);
  }
  candles.forEach((c,i)=>{
    const x=cx(i),isOrb=i<(opts.orbCount||3),bull=c.c>=c.o,hi2=opts.highlightIdx===i;
    const fillC=hi2?'#58cc02':isOrb?(bull?'rgba(88,204,2,.42)':'rgba(255,75,75,.42)'):(bull?'#58cc02':'#ff4b4b');
    const strokeC=hi2?'#46a302':isOrb?(bull?'#58cc02':'#ff4b4b'):(bull?'#46a302':'#cc3b3b');
    ctx.strokeStyle=strokeC;ctx.lineWidth=hi2?2:1.5;ctx.beginPath();ctx.moveTo(x,toY(c.h));ctx.lineTo(x,toY(c.l));ctx.stroke();
    const bT=toY(Math.max(c.o,c.c)),bB=toY(Math.min(c.o,c.c)),bH=Math.max(2,bB-bT);
    ctx.fillStyle=fillC;ctx.fillRect(x-cw/2,bT,cw,bH);ctx.strokeStyle=strokeC;ctx.lineWidth=1;ctx.strokeRect(x-cw/2,bT,cw,bH);
    if(hi2){ctx.strokeStyle='rgba(88,204,2,.4)';ctx.lineWidth=3;ctx.strokeRect(x-cw/2-2,bT-2,cw+4,bH+4);}
    if(c.time&&(i%3===0||candles.length<=8)){ctx.fillStyle='#505060';ctx.font='9px system-ui';ctx.textAlign='center';ctx.fillText(c.time,x,H-6);}
  });
}
